# Configuration Firebase côté navigateur (Auth + Firestore)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Compte de service Firebase Admin (sessions + Firestore)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Sur Vercel, préférez FIREBASE_PRIVATE_KEY_BASE64 (évite les bugs de \\n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY_BASE64=

# Supabase Storage (fichiers — gratuit, remplace Firebase Storage)
SUPABASE_URL=https://ngiyzxlymkslxawbjglj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=hubmaster datafile
# true = bucket public ; false = URLs signées (recommandé)
SUPABASE_STORAGE_PUBLIC=false
