rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return signedIn() && profile().role == "admin"; }
    function isManager() { return signedIn() && profile().role == "manager"; }
    function canReadProject(project) {
      return isAdmin() || isManager() || request.auth.uid in project.memberIds;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth.uid == userId
        && request.resource.data.role == resource.data.role);
    }

    match /projects/{projectId} {
      allow read: if signedIn() && canReadProject(resource.data);
      allow create: if isAdmin() || isManager();
      allow update, delete: if isAdmin() || isManager();
    }

    match /files/{fileId} {
      function project() {
        return get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data;
      }
      allow read: if signedIn() && canReadProject(project());
      allow create, update, delete: if isAdmin() || isManager();
    }
  }
}
